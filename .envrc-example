export LISTMONK_USERNAME="blog-scheduler"
export LISTMONK_API_TOKEN=""

export RSS_URL="https://www.christianconnection.com/dating-advice/feed"

# which listmonk template to use
export LISTMONK_TEMPLATE=35

# comma-separated list IDs to send the campaign to
